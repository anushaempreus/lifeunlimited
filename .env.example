# Resend — https://resend.com/api-keys  (add the real key to .env.local, never commit it)
RESEND_API_KEY=

# Where contact-form enquiries are delivered
CONTACT_TO_EMAIL=info@lifeunlimited.com.au

# Verified sender. Until the domain is verified in Resend, leave unset to use onboarding@resend.dev
CONTACT_FROM_EMAIL=

# Canonical site URL (used for SEO metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
